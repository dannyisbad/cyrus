    {"name": "lone_shell_fence_dominates", "text": "```powershell\nGet-Date\n```", "expect": {"name": "shell_command", "command": "Get-Date"}},
    {"name": "shell_fence_long_prose", "text": "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\n```bash\necho hi\n```", "expect": null},
    {"name": "two_shell_fences", "text": "```sh\na\n```\nand\n```sh\nb\n```", "expect": null},
    {"name": "final_answer_no_fence", "text": "There are 7 items.", "expect": null},
    {"name": "run_fence_wins_over_shell", "text": "```run\nreal\n```\n```powershell\nexample\n```", "expect": {"name": "shell_command", "command": "real"}},
    {"name": "run_fence_multiline_cmd", "text": "```run\nGet-Content a.txt |\n  Select-String foo\n```", "expect": {"name": "shell_command", "command": "Get-Content a.txt |\n  Select-String foo"}},
    {"name": "run_fence_with_quotes_unicode", "text": "```run\nWrite-Output \"café 🚀\"\n```", "expect": {"name": "shell_command", "command": "Write-Output \"café 🚀\""}},
    {"name": "empty_text", "text": "", "expect": null}
