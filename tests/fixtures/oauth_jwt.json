{
  "_comment": "OAuth + JWT differential cases. JWTs are signed over FIXED iat/exp + a FIXED secret so the HS256 signature is reproducible and cross-validates between Node and Rust. PKCE verifiers are the RFC 7636 example plus extras.",
  "secret": "test-secret-differential",
  "jwt_sign": [
    {
      "name": "access_token",
      "claims_order": ["sub", "scope", "iat", "exp"],
      "claims": {"sub": "user", "scope": "mcp", "iat": 1700000000, "exp": 1700003600}
    },
    {
      "name": "refresh_token_no_jti",
      "_note": "jti is random in production; this fixture omits it so the body is deterministic. The real refresh adds type+jti — covered by the refresh roundtrip case which verifies, not byte-compares, the signature.",
      "claims_order": ["sub", "scope", "iat", "exp", "type"],
      "claims": {"sub": "user", "scope": "mcp", "iat": 1700000000, "exp": 1700604800, "type": "refresh"}
    },
    {
      "name": "different_secret_changes_sig",
      "secret_override": "other-secret",
      "claims_order": ["sub", "scope", "iat", "exp"],
      "claims": {"sub": "user", "scope": "mcp", "iat": 1700000000, "exp": 1700003600}
    }
  ],
  "pkce_s256": [
    {"name": "rfc7636_example", "verifier": "dBjftJeZ4CVP-mB92K27uhbUJU1p1r_wW1gFWFOEjXk", "expect_challenge": "E9Melhoa2OwvFrEMTJguCHaoeK1t8URWbuGJSstw-cM"},
    {"name": "short", "verifier": "abc123", "expect_challenge": null},
    {"name": "unicode_verifier", "verifier": "vérifiéur-🚀", "expect_challenge": null}
  ],
  "redirect_allowlist": [
    {"name": "chatgpt_prod_ok", "uri": "https://chatgpt.com/cb", "base": "https://example.cloudflare.dev", "expect": true},
    {"name": "openai_sub_ok", "uri": "https://sub.openai.com/cb", "base": "https://example.cloudflare.dev", "expect": true},
    {"name": "base_host_ok", "uri": "https://example.cloudflare.dev/cb", "base": "https://example.cloudflare.dev", "expect": true},
    {"name": "localhost_blocked_prod", "uri": "https://localhost/cb", "base": "https://example.cloudflare.dev", "expect": false},
    {"name": "http_blocked_prod", "uri": "http://chatgpt.com/cb", "base": "https://example.cloudflare.dev", "expect": false},
    {"name": "arbitrary_blocked", "uri": "https://evil.com/cb", "base": "https://example.cloudflare.dev", "expect": false},
    {"name": "localhost_ok_dev", "uri": "http://localhost:8787/cb", "base": "http://localhost:8787", "expect": true},
    {"name": "garbage_uri", "uri": "not a url", "base": "https://example.cloudflare.dev", "expect": false}
  ],
  "both_chatgpt": [
    {"name": "both_known", "a": "https://chatgpt.com/a", "b": "https://openai.com/b", "expect": true},
    {"name": "one_evil", "a": "https://chatgpt.com/a", "b": "https://evil.com/b", "expect": false}
  ],
  "validate_access_token": [
    {"name": "valid_mcp_scope", "claims_order": ["sub", "scope", "iat", "exp"], "claims": {"sub": "user", "scope": "mcp", "iat": 1700000000, "exp": 4102444800}, "expect": true},
    {"name": "wrong_scope", "claims_order": ["sub", "scope", "iat", "exp"], "claims": {"sub": "user", "scope": "other", "iat": 1700000000, "exp": 4102444800}, "expect": false},
    {"name": "expired_rejected", "claims_order": ["sub", "scope", "iat", "exp"], "claims": {"sub": "user", "scope": "mcp", "iat": 1700000000, "exp": 1700003600}, "expect": false}
  ]
}
