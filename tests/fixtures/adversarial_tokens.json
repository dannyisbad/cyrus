{
  "_comment": "Adversarial token streams. Each case is a list of tokens that get (a) appended to a v1delta assistant message one frame each, and (b) streamed as response.output_text.delta frames. Both originals and the Rust port must round-trip them byte-identically. JSON escapes here are deliberate: \\\\ is a literal backslash token, \\n is a literal newline char, \\\" is a literal quote.",
  "cases": [
    {
      "name": "plain",
      "tokens": ["Hel", "lo", " world"]
    },
    {
      "name": "newlines_tabs_cr",
      "tokens": ["line1\n", "line2\r\n", "\ttabbed", "\n\n"]
    },
    {
      "name": "quotes_and_backslashes",
      "tokens": ["a \"quote\"", " and a \\ backslash", " and \\\"escaped\\\"", " and \\n two-char literal"]
    },
    {
      "name": "unicode",
      "tokens": ["café", " — em-dash", " 🚀 rocket", " 日本語", " ℝ-ish", "  nbsp"]
    },
    {
      "name": "fake_sentinels",
      "tokens": ["<<<sentinel>>>", " <<<not a sentinel>>>", " ```run\necho hi\n```", " [[END]]", " <script>"]
    },
    {
      "name": "json_control_chars",
      "tokens": ["{\"k\":\"v\"}", " [1,2,3]", " null", " \\u0041 two-char", " \b\f"]
    },
    {
      "name": "mixed_heavy",
      "tokens": ["Mix: ", "\"q\"", "\\b two-char", "\n", "🚀", "<<<x>>>", "\t", "日", "\\\\", "end"]
    }
  ]
}
